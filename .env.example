# =============================================================================
# DILEMMA 環境変数テンプレート
# =============================================================================
# コピーして .env.local を作成:  cp .env.example .env.local
# .env.local は .gitignore 対象（コミット禁止）
# Vercel環境変数にも同じキーを設定すること
# =============================================================================

# --- アプリケーション ---
NEXT_PUBLIC_APP_URL=http://localhost:3000

# --- Neon PostgreSQL ---
# Neonダッシュボード → Connection Details → Connection string
DATABASE_URL=postgresql://[user]:[password]@[endpoint].neon.tech/[dbname]?sslmode=require

# --- Better Auth ---
# openssl rand -hex 32 で生成
BETTER_AUTH_SECRET=[32バイト以上のランダム文字列]
BETTER_AUTH_URL=http://localhost:3000

# --- Gemini API（LLMエージェント4体のテキスト生成） ---
# Google AI Studio → API Keys
GEMINI_API_KEY=[Gemini API キー]

# --- V7推論エンジン（Go pace-inference） ---
# ローカル開発: http://localhost:8080
# 本番: デプロイ先URL
PACE_INFERENCE_URL=http://localhost:8080
# TSフォールバック有効化（Go推論サービス障害時）
PACE_INFERENCE_TS_FALLBACK=true

# --- Stripe（課金） ---
# Stripe Dashboard → Developers → API Keys
STRIPE_SECRET_KEY=[sk_test_... or sk_live_...]
STRIPE_WEBHOOK_SECRET=[whsec_...]
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=[pk_test_... or pk_live_...]

# --- Sentry（監視） ---
# Sentry → Settings → Client Keys (DSN)
NEXT_PUBLIC_SENTRY_DSN=[https://xxxxx@sentry.io/xxxxx]
SENTRY_AUTH_TOKEN=[Sentry認証トークン（ソースマップアップロード用）]

# --- Neon コールドスタート対策 ---
# Vercel Cron で5分ごとに keep-alive ping を実行
# vercel.json の crons 設定で自動化済み
NEON_KEEPALIVE_ENABLED=true
